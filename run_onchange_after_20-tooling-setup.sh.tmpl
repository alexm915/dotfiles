#!/usr/bin/env bash
set -euo pipefail

info() {
  printf '[info] %s\n' "$*"
}
warn() {
  printf '[warn] %s\n' "$*" >&2
}
have() {
  command -v "$1" >/dev/null 2>&1
}

install_tpm() {
  local tpm_dir="${XDG_CONFIG_HOME:-$HOME/.config}/tmux/plugins/tpm"
  [[ -d "$tpm_dir" ]] && return 0

  info "Installing tmux TPM..."
  mkdir -p "$(dirname "$tpm_dir")"
  git clone --depth=1 https://github.com/tmux-plugins/tpm "$tpm_dir"
}

install_zimfw() {
  if [[ -f "${HOME}/.zim/zimfw.zsh" ]]; then
    return 0
  fi

  if ! have zsh; then
    warn 'zsh not found; skipping zimfw installation'
    return 0
  fi

  info 'Installing zimfw...'
  curl -fsSL https://raw.githubusercontent.com/zimfw/install/master/install.zsh | zsh
}

configure_yazi() {
  if ! have ya; then
    warn 'ya not found; skipping yazi plugin installation'
    return 0
  fi

  info 'Installing yazi plugins...'
  local -a plugins=(
    yazi-rs/plugins:full-border
    yazi-rs/plugins:git
    Rolv-Apneseth/starship
    KKV9/compress
    h-hg/yamb
    imsi32/yatline
  )

  local plugin
  for plugin in "${plugins[@]}"; do
    ya pkg add "$plugin" || true
  done
}

set_default_shell() {
  if ! have zsh; then
    return 0
  fi

  local zsh_path
  zsh_path="$(command -v zsh)"

  if [[ "$SHELL" == "$zsh_path" ]]; then
    return 0
  fi

  if ! grep -qxF "$zsh_path" /etc/shells 2>/dev/null; then
    warn "$zsh_path is not listed in /etc/shells; skipping chsh"
    return 0
  fi

  info "Setting default shell to ${zsh_path}"
  chsh -s "$zsh_path"
  info 'Default shell updated. It will take effect on the next login.'
}

sync_neovim() {
  if ! have nvim; then
    warn 'Neovim not found; skipping plugin sync'
    return 0
  fi

  info 'Syncing Neovim plugins...'
  nvim --headless '+Lazy! sync' +qa || warn 'Neovim plugin sync failed'
}

main() {
  install_tpm
  install_zimfw
  configure_yazi
  set_default_shell
  sync_neovim
}

main "$@"